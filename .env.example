# Copy to .env and fill in. .env is git-ignored and MUST NOT be committed.
# CDK reads these at deploy time and sets them as Lambda environment variables.

# Telegram bot token from @BotFather. ROTATE if it has ever been committed/shared.
TOKEN=your-telegram-bot-token
# Telegram chat id the bot is allowed to talk to.
CHATID=your-chat-id

# AWS deployment target
AWS_ACCOUNT_ID=your-aws-account-id
AWS_REGION=your-aws-region
AWS_PROFILE=your-aws-profile
